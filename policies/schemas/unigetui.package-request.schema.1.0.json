{
  "$id": "https://aka.ms/unigetui/package-request.schema.1.0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UniGetUI Package Broker Request Schema",
  "description": "Canonical request sent by an unelevated UniGetUI process to an elevated broker for package operations.",
  "type": "object",
  "required": [
    "requestVersion",
    "requestType",
    "requestId",
    "createdAt",
    "operation",
    "manager",
    "source",
    "package",
    "options",
    "broker"
  ],
  "properties": {
    "$schema": {
      "$ref": "#/$defs/url"
    },
    "requestVersion": {
      "$ref": "#/$defs/semanticVersion",
      "default": "1.0.0",
      "description": "The request syntax version."
    },
    "requestType": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$",
      "default": "packageOperation",
      "description": "The request type. Recognized values: packageOperation."
    },
    "requestId": {
      "$ref": "#/$defs/resourceId",
      "description": "Unique client-generated request id used for audit correlation."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when the client created the request."
    },
    "operation": {
      "$ref": "#/$defs/operation"
    },
    "manager": {
      "$ref": "#/$defs/manager"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "package": {
      "$ref": "#/$defs/package"
    },
    "options": {
      "$ref": "#/$defs/options"
    },
    "broker": {
      "$ref": "#/$defs/brokerContext"
    }
  },
  "$defs": {
    "semanticVersion": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$",
      "maxLength": 128
    },
    "resourceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "maxLength": 128
    },
    "url": {
      "type": "string",
      "pattern": "^([Hh][Tt][Tt][Pp][Ss]?)://.+$",
      "maxLength": 2048
    },
    "operation": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$",
      "description": "The UniGetUI package operation. Recognized values: install, update, uninstall."
    },
    "scope": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$",
      "description": "Scope value. Recognized values: user, machine."
    },
    "architecture": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$",
      "description": "Architecture value. Recognized values: x86, x64, arm32, arm64, neutral."
    },
    "managerName": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$",
      "description": "Manager name. Recognized values include: Winget, PowerShell, Scoop, Chocolatey, Pip, Npm, Dotnet, Cargo, Homebrew, Pacman, Dnf, Apt, Flatpak."
    },
    "packageIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[^\\/:*?\"<>|\\x01-\\x1f]+$",
      "description": "Package identifier as reported by the package manager. WinGet identifiers should use Publisher.Package form."
    },
    "manager": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/managerName"
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "executableFriendlyName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "source": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "url": {
          "$ref": "#/$defs/url"
        },
        "isVirtualManager": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "package": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/packageIdentifier"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "version": {
          "type": "string",
          "maxLength": 128
        },
        "newVersion": {
          "type": "string",
          "maxLength": 128
        },
        "channel": {
          "type": "string",
          "minLength": 1,
          "maxLength": 16
        }
      }
    },
    "options": {
      "type": "object",
      "properties": {
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "architecture": {
          "$ref": "#/$defs/architecture"
        },
        "version": {
          "type": "string",
          "maxLength": 128,
          "description": "Requested install version. Empty or omitted means the manager default."
        },
        "interactive": {
          "type": "boolean"
        },
        "runAsAdministrator": {
          "type": "boolean"
        },
        "skipHashCheck": {
          "type": "boolean"
        },
        "preRelease": {
          "type": "boolean"
        },
        "customInstallLocation": {
          "type": "string",
          "maxLength": 2048
        },
        "customParameters": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "maxItems": 64
        },
        "preOperationCommand": {
          "type": "string",
          "maxLength": 2048
        },
        "postOperationCommand": {
          "type": "string",
          "maxLength": 2048
        },
        "killBeforeOperation": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "maxItems": 64,
          "uniqueItems": true
        }
      }
    },
    "brokerContext": {
      "type": "object",
      "required": [
        "requestedElevation"
      ],
      "properties": {
        "requestedElevation": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$",
          "description": "Requested elevation level. Recognized values: standard, elevated."
        },
        "effectiveUser": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Optional. The effective user identity. When omitted, the broker derives it from the transport authentication."
        },
        "clientVersion": {
          "type": "string",
          "maxLength": 128
        },
        "clientProcessPath": {
          "type": "string",
          "maxLength": 2048
        }
      }
    }
  }
}